terraform {
  required_version = ">= 1.5"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    google-beta = {
      source  = "hashicorp/google-beta"
      version = ">= 5.0"
    }
  }
  backend "gcs" {
    bucket = "tty-theme-tfstate"
    prefix = "terraform/state"
  }
}
